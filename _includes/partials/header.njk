<header id="header" class="header sticky-top">
  <div class="container-xl">
    <div class="d-flex align-items-center justify-content-between py-3">

      <a href="{{ '/' | url }}" class="logo d-flex align-items-center text-decoration-none">
        <span class="sitename">{{ site.brand.name }}</span>
      </a>

      <nav id="navmenu" class="navmenu">
        <ul class="d-flex align-items-center gap-3 list-unstyled mb-0">
          {% for item in site.nav %}
            {% if item.children %}
              <li class="dropdown position-relative">
                <a href="{{ item.url | url }}" class="d-inline-flex align-items-center gap-1">
                  <span>{{ item.label }}</span>
                  <i class="bi bi-chevron-down toggle-dropdown"></i>
                </a>
                <ul class="dropdown-menu-custom list-unstyled">
                  {% for child in item.children %}
                    <li><a href="{{ child.url | url }}">{{ child.label }}</a></li>
                  {% endfor %}
                </ul>
              </li>
            {% else %}
              <li><a href="{{ item.url | url }}" {% if item.url == page.url or (item.active and page.url == '/') %}class="active"{% endif %}>{{ item.label }}</a></li>
            {% endif %}
          {% endfor %}
        </ul>
        <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
      </nav>

    </div>
  </div>
</header>

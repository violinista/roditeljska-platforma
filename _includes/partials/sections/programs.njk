<section id="featured-programs" class="featured-programs section">
  <div class="container">

    <div class="section-title text-center mb-5">
      <h2>Vodiči i teme</h2>
      <p>Naši ključni materijali za roditelje</p>
    </div>

    <div class="row g-4 align-items-stretch">

      <div class="col-lg-7">
        <div class="program-banner h-100">
          <img src="{{ programs.featured.image }}" alt="{{ programs.featured.title }}" class="img-fluid rounded mb-3">
          <span class="banner-badge">{{ programs.featured.badge }}</span>
          <h3 class="mt-3">{{ programs.featured.title }}</h3>
          <p>{{ programs.featured.summary }}</p>
          <div class="program-stats d-flex flex-wrap gap-4 my-3">
            {% for s in programs.featured.stats %}
              <div>
                <strong class="d-block">{{ s.value }}</strong>
                <span>{{ s.label }}</span>
              </div>
            {% endfor %}
          </div>
          <a href="{{ programs.featured.cta.url }}" class="discover-btn">{{ programs.featured.cta.label }} <i class="bi bi-arrow-right"></i></a>
        </div>
      </div>

      <div class="col-lg-5">
        <div class="d-flex flex-column gap-3 h-100">
          {% for p in programs.grid %}
            <a href="{{ p.url }}" class="program-item d-flex align-items-center justify-content-between text-decoration-none">
              <div>
                <h4 class="mb-1">{{ p.title }}</h4>
                <p class="mb-0">{{ p.summary }}</p>
              </div>
              <span class="item-arrow flex-shrink-0"><i class="bi bi-arrow-right"></i></span>
            </a>
          {% endfor %}
        </div>
      </div>

    </div>
  </div>
</section>

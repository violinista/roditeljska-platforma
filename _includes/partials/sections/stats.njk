<section id="stats" class="stats section">
  <div class="container">

    <div class="row row-cols-2 row-cols-lg-4 g-4 mb-5">
      {% for m in metrics %}
        <div class="col">
          <div class="metric-card h-100 text-center">
            <div class="metric-icon-wrapper mb-3"><i class="bi {{ m.icon }}"></i></div>
            <div class="metric-value">{{ m.value }}{{ m.suffix }}</div>
            <p class="mb-0">{{ m.label }}</p>
          </div>
        </div>
      {% endfor %}
    </div>

    <div class="row g-5 align-items-center highlights-section">

      <div class="col-lg-6">
        <h3 class="mb-3">{{ highlights.title }}</h3>
        <p class="mb-4">{{ highlights.lede }}</p>
        <ul class="highlights-features list-unstyled mb-0">
          {% for f in highlights.features %}
            <li class="feature-item d-flex gap-3 mb-3">
              <i class="bi {{ f.icon }} flex-shrink-0"></i>
              <div>
                <strong class="d-block">{{ f.title }}</strong>
                <span>{{ f.body }}</span>
              </div>
            </li>
          {% endfor %}
        </ul>
      </div>

      <div class="col-lg-6">
        <div class="gallery-grid">
          {% for g in highlights.gallery %}
            <div class="gallery-item gallery-item-{{ g.size }}">
              <img src="{{ g.image | url }}" alt="{{ g.alt }}" class="img-fluid">
            </div>
          {% endfor %}
        </div>
      </div>

    </div>
  </div>
</section>
